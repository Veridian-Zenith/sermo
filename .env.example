# ---- Database ----
DB_USER=sermo
# CHANGE THIS to a long random password before deploying.
DB_PASSWORD=CHANGE_ME_strong_password
DB_NAME=sermo

# ---- Phoenix production release ----
# Generate a secret with:  mix phx.gen.secret
SECRET_KEY_BASE=REPLACE_WITH_mix_phx_gen_secret_OUTPUT

# 32 bytes, base64-encoded. Generate with:
#   mix run -e 'IO.puts(:crypto.strong_rand_bytes(32) |> Base.encode64())'
RECOVERY_ENCRYPTION_KEY=REPLACE_WITH_32_BYTE_BASE64_KEY

# The public host browsers will use, e.g. chat.indevs.in or a new free domain.
# Caddy (in docker-compose.yml) obtains the TLS certificate for this automatically.
PHX_HOST=your-domain.example

# DB connection pool size — keep small on the free tier.
POOL_SIZE=2

# The release also reads DATABASE_URL / PORT / SECRET_KEY_BASE / PHX_HOST /
# RECOVERY_ENCRYPTION_KEY / POOL_SIZE from the environment (see config/runtime.exs).
