  email you@example.com
}

# Replace with the domain you point at this server via your self-hosted DNS.
# Caddy obtains and renews a free TLS certificate automatically (ACME HTTP-01),
# so port 80 must be reachable from the internet.
your-domain.example {

  # Increase timeouts for long-lived LiveView websocket connections.
  reverse_proxy app:4000
}
